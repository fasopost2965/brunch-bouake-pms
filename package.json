{
  "name": "brunch-bouake-pms",
  "version": "0.1.0",
  "private": true,
  "description": "PMS hôtelier Brunch Bouaké — Bouaké, Côte d'Ivoire",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@9.2.0",
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
