# ============================================
# Brunch Bouaké PMS — Environment Variables
# ============================================
# Copy this file to .env and fill in real values
# cp .env.example .env

# ── MySQL (Docker) ──────────────────────────
MYSQL_ROOT_PASSWORD=brunch_root_2026
MYSQL_DATABASE=brunch_bouake_pms
MYSQL_USER=brunch_user
MYSQL_PASSWORD=brunch_pass_2026

# ── Prisma Database URL ─────────────────────
DATABASE_URL="mysql://brunch_user:brunch_pass_2026@localhost:3306/brunch_bouake_pms"

# ── Backend (NestJS) ────────────────────────
BACKEND_PORT=3001
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=24h

# ── Frontend (Next.js) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_PORT=3000

# ── General ──────────────────────────────────
NODE_ENV=development
TZ=Africa/Abidjan
